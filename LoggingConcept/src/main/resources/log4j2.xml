<?xml version="1.0" encoding="UTF-8"?>

<Configuration status="INFO">
	<Appenders>
		<Console name="loggingToConsole" target="SYSTEM_OUT">
			<PatternLayout>
				<Pattern>
					%d - %c - [%M] - (%p) - %m - %n
				</Pattern>
			</PatternLayout>
		</Console>
		
		<File name="loggingToFile" fileName="logg/logger.log">
			<PatternLayout>
				<Pattern>
					%d - %c - [%M] - (%p) - %m - %n
				</Pattern>
			</PatternLayout>
		</File>
	</Appenders>
	
	<Loggers>
		<Root level="info">
			<AppenderRef ref="loggingToConsole"/>
			<AppenderRef ref="loggingToFile"/>
		</Root>
	</Loggers>
</Configuration>